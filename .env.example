# HTTP agent - chi nghe loopback, truy cap tu ngoai di qua cloudflared + Access
PORT=9100
STATION=kho-bd

# Cloudflare Access - verify JWT tu header cf-access-jwt-assertion
CF_TEAM_DOMAIN=dilim.cloudflareaccess.com
# AUD tag cua Access application (Zero Trust dashboard > Access > Applications > Overview)
CF_ACCESS_AUD=<aud_tag>

# May in va duong dan chuong trinh
PRINTER_NAME=SP46 (Copy 1)
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
SUMATRA_PATH=C:\Users\ADMIN\AppData\Local\SumatraPDF\SumatraPDF.exe

# Thong bao Zalo khi in loi (qua zalo-bridge)
ZALO_BRIDGE_URL=https://zb.dilisupplement.com/send
ZALO_BRIDGE_KEY=<bridge_key>
ZALO_THREAD_ID=<thread_id>
ZALO_THREAD_TYPE=group
